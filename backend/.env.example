# Copy to .env and fill in. Without a key, the app still runs (technical signals only).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Durable history (optional). Without these, prediction/accuracy/paper-trade
# history is stored in a local SQLite file that resets on serverless cold starts.
# Point at a free Turso/libSQL database to persist it (see DEPLOY.md §3).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Alerts (optional). When set, signal-flip / price alerts are also relayed to
# these channels by POST /notify. Leave blank to use browser notifications only.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
